CLAUDE_API_KEY=your_claude_api_key_here
PORT=3001
NODE_ENV=production

# Base path for the app (useful for reverse proxy setups)
# For root deployment: BASE_PATH=""
# For subdirectory: BASE_PATH="/indianhistorybite"
BASE_PATH=/indianhistorybite

# Runtime directory (relative to app directory)
RUNTIME_DIR=../runtime

# Security: API key for protecting admin endpoints (generate a strong random key)
APP_API_KEY=your_secure_app_api_key_here

# Security: Comma-separated list of allowed origins for CORS
# Add your domain(s) here
ALLOWED_ORIGINS=https://app.gyatso.me
# Web push notifications (generate with `npx web-push generate-vapid-keys`)
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
